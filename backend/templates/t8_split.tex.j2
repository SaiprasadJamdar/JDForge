\documentclass[10pt,a4paper]{article}

\usepackage[top=0pt,bottom=0pt,left=0pt,right=0pt]{geometry}
\usepackage{graphicx}
\usepackage{xcolor}
\usepackage[normalem]{ulem}
\usepackage{paracol}
\usepackage{titlesec}
\usepackage{enumitem}
\usepackage{helvet}
\usepackage[T1]{fontenc}
\renewcommand{\familydefault}{\sfdefault}

\definecolor{primary}{RGB}{37,99,235}
\definecolor{sidebar}{RGB}{232,240,255}
\definecolor{sideborder}{RGB}{186,210,253}
\definecolor{textgray}{RGB}{60,75,95}
\definecolor{textdark}{RGB}{15,23,42}
\definecolor{rulecol}{RGB}{203,213,225}

\titleformat{\section}
  {\raggedright\normalsize\bfseries\color{primary}}
  {}{0em}{\MakeUppercase}
  [{\color{rulecol}\vspace{2pt}\hrule height 0.5pt\vspace{4pt}}]
\titlespacing*{\section}{0pt}{11pt}{2pt}

\setlist[itemize]{noitemsep,topsep=2pt,leftmargin=1.3em,
  label={\color{primary}$\bullet$}}
\setlength{\parindent}{0pt}
\setlength{\parskip}{4pt}

\begin{document}
\pagestyle{empty}

\columnratio{0.29}
\setlength{\columnsep}{0pt}

\begin{paracol}{2}

%% ─── LEFT SIDEBAR ────────────────────────────────────────────────────────────
\backgroundcolor{c[0]}{sidebar}
\setlength{\leftskip}{10pt}
\setlength{\rightskip}{8pt}

\vspace*{24pt}

\noindent\begin{center}
  \includegraphics[width=4.8cm]{image.jpg}
\end{center}

\vspace{14pt}
\noindent{\color{sideborder}\hrule height 1pt}
\vspace{14pt}

<% for meta in metadata %>
\noindent{\fontsize{7}{8}\selectfont\bfseries\color{primary}\MakeUppercase{<< meta.label >>}}

\vspace{2pt}
\noindent{\fontsize{9}{13}\selectfont\color{textgray}\raggedright << meta.value >>}

\vspace{13pt}
<% endfor %>

\switchcolumn

%% ─── RIGHT CONTENT ───────────────────────────────────────────────────────────
%% NO minipage – lets long content flow freely to next pages
\setlength{\leftskip}{18pt}
\setlength{\rightskip}{18pt}

\vspace*{24pt}

\noindent{\fontsize{20}{25}\selectfont\bfseries\color{textdark}\raggedright << hiring_title >>}

\vspace{8pt}
\noindent{\color{primary}\hrule height 2.5pt}
\vspace{2pt}
\noindent{\color{rulecol}\hrule height 0.4pt}
\vspace{14pt}

<% for section in body_sections %>
\section*{<< section.title >>}
\noindent{\fontsize{9}{13.5}\selectfont\color{textgray}
  <% if section.is_list %>
    \begin{itemize}
    << section.content >>
    \end{itemize}
  <% else %>
    \raggedright << section.content >>
  <% endif %>
}
<% endfor %>

\end{paracol}
\end{document}
