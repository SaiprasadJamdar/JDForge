\documentclass[11pt,a4paper]{article}

\usepackage[margin=0.6in]{geometry}
\usepackage{graphicx}
\usepackage{xcolor}
\usepackage[normalem]{ulem}
\usepackage{titlesec}
\usepackage{enumitem}
\usepackage{tcolorbox}
\tcbuselibrary{breakable}
\usepackage{helvet}
\renewcommand{\familydefault}{\sfdefault}

\definecolor{primary}{RGB}{0,102,153}
\definecolor{textgray}{RGB}{60,60,60}
\definecolor{lightbg}{RGB}{245,247,250}

\titleformat{\section}{\Large\bfseries\color{primary}}{}{0em}{}
\titlespacing*{\section}{0pt}{10pt}{6pt}
\setlist[itemize]{noitemsep, topsep=2pt, leftmargin=1.3em}
\setlength{\parindent}{0pt}
\setlength{\parskip}{4pt}

\begin{document}

\begin{minipage}{0.7\textwidth}
{\Huge\bfseries\color{primary} << hiring_title >>}
\vspace{2pt}

{\large Wissen Technology}
\end{minipage}
\hfill
\begin{minipage}{0.25\textwidth}
\raggedleft
\includegraphics[width=4.5cm]{image.jpg}
\end{minipage}

\vspace{4pt}
\hrule height 1pt
\vspace{6pt}

<% if metadata %>
\begin{tcolorbox}[colback=lightbg,colframe=white,arc=4pt,boxrule=0pt,breakable]
\centering
<% for meta in metadata %>
\textbf{<< meta.label >>:} << meta.value >> <% if not loop.last %> \hfill | \hfill <% endif %>
<% endfor %>
\end{tcolorbox}
<% endif %>

\begin{tcolorbox}[colback=white,colframe=primary,arc=3pt,breakable]

<% for section in body_sections %>
\section*{<< section.title >>}
{\color{textgray}
  <% if section.is_list %>
    \begin{itemize}
    << section.content >>
    \end{itemize}
  <% else %>
    << section.content >>
  <% endif %>
}
<% endfor %>

\end{tcolorbox}

\end{document}
