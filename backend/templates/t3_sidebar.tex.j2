\documentclass[9pt,a4paper]{article}

\usepackage[margin=0.5in]{geometry}
\usepackage{graphicx}
\usepackage{xcolor}
\usepackage[normalem]{ulem}
\usepackage{tikz}
\usepackage{titlesec}
\usepackage{enumitem}
\usepackage{helvet}
\renewcommand{\familydefault}{\sfdefault}

\definecolor{primary}{RGB}{0,102,153}
\definecolor{panel}{RGB}{220,230,240}
\definecolor{textgray}{RGB}{80,80,80}

\titleformat{\section}{\normalsize\bfseries\color{primary}}{}{0em}{}
\titlespacing*{\section}{0pt}{5pt}{2pt}
\setlist[itemize]{noitemsep, topsep=0pt, leftmargin=1.1em}
\setlength{\parindent}{0pt}
\setlength{\parskip}{2pt}

\begin{document}

\begin{tikzpicture}[remember picture,overlay]
\fill[panel] (current page.north west) rectangle ([xshift=5cm]current page.south west);
\end{tikzpicture}

\begin{tabular}{@{\hspace{-9pt}}p{3.8cm}@{\hspace{1.2cm}}p{13.2cm}@{}}

\begin{minipage}[t]{\linewidth}
\vspace{0pt}
\includegraphics[width=3cm]{image.jpg}

\vspace{10pt}
<% for meta in metadata %>
\textbf{<< meta.label >>}\\ << meta.value >>
\vspace{6pt}
<% endfor %>
\end{minipage}

&

\begin{minipage}[t]{\linewidth}
\vspace{0pt}

{\Large\bfseries\color{primary} << hiring_title >>}

\vspace{4pt}
\hrule
\vspace{6pt}


<% for section in body_sections %>
\section*{<< section.title >>}
{\color{textgray}
  <% if section.is_list %>
    \begin{itemize}
    << section.content >>
    \end{itemize}
  <% else %>
    << section.content >>
  <% endif %>
}
<% endfor %>

\end{minipage}
\end{tabular}

\end{document}
